<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduSpark</title>
    <link rel="stylesheet" href="paper.css">
    <link rel="stylesheet" href="style.css">
</head>
<body>
   
<form class="ff-ff" action="/download" method="get">
    <button class="primary-btn">Download</button>
</form><br><div class="pap-head">
<img class="logo" src="https://image2url.com/r2/default/images/1774877777631-c38ec464-c4e5-4b44-8a74-48f22bb64834.jpeg"
 alt="logo">
<h1>EduSpark</h1></div>

<% let i = 0; %>
<% for (const q of question) { %>
    <% if (typeof q === 'string') { i = 0; %>
    <h5><%= q %></h5>
    <% } else if (q && q.questionType === "MCQ") { const options = Array.isArray(q.options) ? q.options : []; i = i + 1; %>
        <h3>(<%=i%>)&nbsp;<%=q.questionText%></h3>
        <p>(A)&nbsp;<%=options[0] || ""%></p>
        <p>(B)&nbsp;<%=options[1] || ""%></p>
        <p>(C)&nbsp;<%=options[2] || ""%></p>
        <p>(D)&nbsp;<%=options[3] || ""%></p><br>
        
    <% } else if (q) { %>
           <% if(q.hasImage === "yes"){i=i+1;%>
                <h3>(<%=i%>)&nbsp;<%=q.questionText%></h3>
                <img class="center" src="<%=q.image%>" alt="question image">  <br> 
            <%}else{%>
                <%i=i+1;%>
            <h3>(<%=i%>)&nbsp;<%=q.questionText%></h3><br>
            <%}%>
<% } } %>

</body>
</html>

 
